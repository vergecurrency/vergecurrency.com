    "glob": "^11.1.0",
    "glob-all": "^3.1.0",
    "i18next": "^10.3.0",
    "i18next-browser-languagedetector": "^2.1.0",
    "i18next-fs-backend": "2.6.1",
    "i18next-http-middleware": "3.9.2",
    "isomorphic-unfetch": "^4.0.2",
    "moment": "^2.29.4",
    "moment-timezone": "0.6.0",
    "next": "12.3.4",
    "normalize.css": "^8.0.1",
    "npm-update-all": "^1.0.1",
    "nprogress": "^0.2.0",
